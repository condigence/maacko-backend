# Copy this file to .env and adjust as needed. All values below are dev defaults
# already hardcoded as fallbacks in code, so the app runs without a .env at all.

# --- Ports / service discovery ---
PORT=3000
USER_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
AUTH_SERVICE_PORT=3003
PAYMENT_SERVICE_PORT=3004
GATEWAY_URL=http://127.0.0.1:3000
USER_SERVICE_URL=http://127.0.0.1:3001
PRODUCT_SERVICE_URL=http://127.0.0.1:3002
AUTH_SERVICE_URL=http://127.0.0.1:3003
PAYMENT_SERVICE_URL=http://127.0.0.1:3004

# --- MySQL (user-service only; auth-service uses a local JSON mock store, no DB needed) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=maako

# --- MongoDB (product-service) ---
MONGO_URI=mongodb://127.0.0.1:27017/maako

# --- Auth service: JWT secrets (CHANGE THESE for anything beyond local dev) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Auth service: OTP behavior ---
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=30

# When NODE_ENV=production, /auth/*/otp/request stops echoing the OTP back
# in the response body (devOtp) since no real SMS/email provider is wired up yet.
NODE_ENV=development

# --- Payment service: Razorpay Standard Checkout (test mode keys, see Razorpay dashboard) ---
# KEY_SECRET must never be exposed to any frontend code - server-side use only.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
